{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["DOM", "ES2022"],
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@map/*": ["./src/components/map/*"]
    }
  },
  "include": ["src", "vite.config.ts", "vitest.shims.d.ts"],
  "exclude": ["dist", "node_modules"]
}
